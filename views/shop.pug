extends layouts/main-layout.pug

block styles
    link(rel="stylesheet", href="/css/product.css")
    title #{pageTitle}

block content
    main 
        .grid  
             
            h1 Product List
            each prod in prods
                
                .product-item
                    div.card_image
                        img(src="data:image/jpeg;base64,", alt="#{prod.title}")
                    h2 #{prod.title}
                    
                    
            


